DATABASE_URL="postgresql://spark:spark@127.0.0.1:5435/tenegta_spark"
REDIS_URL="redis://localhost:6382"
RATE_LIMIT_INTERNAL_SECRET="dev-rate-limit-secret-change-in-production"
NEXTAUTH_SECRET="dev-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
CRON_SECRET="dev-cron-secret"

# Error monitoring (optional in dev)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_RELEASE="tenegta-spark@0.1.0"
NEXT_PUBLIC_SENTRY_RELEASE="tenegta-spark@0.1.0"
SENTRY_ENVIRONMENT="development"
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"
SENTRY_ORG=""
SENTRY_PROJECT=""
ENABLE_SENTRY_TEST="1"

# Transactional email via Resend
RESEND_API_KEY=""
EMAIL_FROM="TENEGTA Spark <noreply@tenegta.com>"
# Optional: receive top-up approval emails in dev/staging
TOPUP_NOTIFY_EMAIL=""
OPS_ALERT_EMAIL=""

# Private file storage — local by default; S3-compatible when set
STORAGE_PROVIDER="local"
STORAGE_ENDPOINT=""
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY=""
# S3 writes when STORAGE_* set; reads stay local until STORAGE_READ_CANARY=1
STORAGE_READ_CANARY="0"

# E2E / visual audit — skip login rate limit in dev and CI
DISABLE_LOGIN_RATE_LIMIT="0"

# Landing A/B experiment: control | variant_a | variant_b
NEXT_PUBLIC_LANDING_EXPERIMENT="control"

# Stripe checkout (optional)
FEATURE_STRIPE_CHECKOUT="0"
NEXT_PUBLIC_STRIPE_CHECKOUT="0"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_OAUTH="0"

# Meilisearch (optional — falls back to Prisma search)
MEILISEARCH_HOST=""
MEILISEARCH_API_KEY=""

# Web push PWA banner (optional)
NEXT_PUBLIC_WEB_PUSH="0"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
